    "options": "Patient",
    "req": 1,
    "in_list_view": 1
   },
  {
   "fieldname": "patient_name",
   "label": "Patient Name",
   "fieldtype": "Data",
   "read_only": 1,
   "fetch_from": "patient.patient_name"
  },
   {
    "fieldname": "practitioner",
    "label": "Practitioner",
    "fieldtype": "Link",
    "options": "Healthcare Practitioner",
    "req": 1,
    "in_list_view": 1
   },
  {
   "fieldname": "encounter",
   "label": "Encounter",
   "fieldtype": "Link",
   "options": "Patient Encounter"
  },
   {
    "fieldname": "department",
    "label": "Department",
    "fieldtype": "Link",
    "options": "Medical Department",
    "in_standard_filter": 1
   },
   {
    "fieldname": "start_date",
    "label": "Start Date",
    "fieldtype": "Date",
    "default": "Today",
