{
 "doctype": "DocType",
 "module": "FINANCE",
 "name": "Financial Report",
 "description": "Generate and manage financial reports and statements",
 "fields": [
  {
   "fieldname": "report_name",
   "label": "Report Name",
   "fieldtype": "Data",
   "req": 1
  },
  {
   "fieldname": "report_type",
   "label": "Report Type",
   "fieldtype": "Select",
   "options": "Balance Sheet\nIncome Statement\nCash Flow Statement\nTrial Balance\nProfit & Loss\nAccounts Receivable Aging\nAccounts Payable Aging\nGeneral Ledger",
   "req": 1
  },
  {
   "fieldname": "report_period",
   "label": "Report Period",
   "fieldtype": "Select",
   "options": "Daily\nWeekly\nMonthly\nQuarterly\nYearly\nCustom"
  },
  {
   "fieldname": "start_date",
   "label": "Start Date",
   "fieldtype": "Date"
  },
  {
   "fieldname": "end_date",
   "label": "End Date",
   "fieldtype": "Date"
  },
  {
   "fieldname": "department",
   "label": "Department",
   "fieldtype": "Link",
   "options": "Department"
  },
  {
   "fieldname": "cost_center",
   "label": "Cost Center",
   "fieldtype": "Link",
   "options": "Cost Center"
  },
  {
   "fieldname": "account",
   "label": "Account",
   "fieldtype": "Link",
   "options": "Account"
  },
  {
   "fieldname": "include_zero_balanced_accounts",
   "label": "Include Zero Balanced Accounts",
   "fieldtype": "Check",
   "default": 0
  },
  {
   "fieldname": "show_converted_amounts",
   "label": "Show Converted Amounts",
   "fieldtype": "Check",
   "default": 0
  },
  {
   "fieldname": "email_report",
   "label": "Email Report",
   "fieldtype": "Check"
  },
  {
   "fieldname": "email_addresses",
   "label": "Email Addresses",
   "fieldtype": "Data"
  },
  {
   "fieldname": "report_file",
   "label": "Report File",
   "fieldtype": "Attach"
  },
  {
   "fieldname": "generated_by",
   "label": "Generated By",
   "fieldtype": "Link",
   "options": "Employee"
  },
  {
   "fieldname": "generated_on",
   "label": "Generated On",
   "fieldtype": "Date",
   "default": "today"
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "Draft\nGenerated\nSent\nCancelled",
   "default": "Draft"
  },
  {
   "fieldname": "remarks",
   "label": "Remarks",
   "fieldtype": "Text"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1
  },
  {
   "role": "Accountant",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0
  },
  {
   "role": "Finance Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0
  },
  {
   "role": "HR Manager",
   "read": 1,
   "write": 0,
   "create": 0,
   "delete": 0
  }
 ]
}