   "options": "party_type",
   "req": 1
  },
  {
   "fieldname": "amount",
   "label": "Amount",
   "fieldtype": "Currency",
   "req": 1
  },
  {
   "fieldname": "mode_of_payment",
   "label": "Mode of Payment",
   "fieldtype": "Select",
   "options": "Bank Transfer\nCheque\nCash\nCredit Card\nDigital Wallet\nPayPal"
  },
  {
   "fieldname": "bank_account",
   "label": "Bank Account",
   "fieldtype": "Link",
   "options": "Bank Account"
  },
  {
   "fieldname": "cheque_number",
   "label": "Cheque Number",
   "fieldtype": "Data"
  },
  {
   "fieldname": "reference_no",
   "label": "Reference No",
   "fieldtype": "Data"
  },
  {
   "fieldname": "reference_date",
   "label": "Reference Date",
   "fieldtype": "Date"
  },
  {
   "fieldname": "description",
   "label": "Description",
   "fieldtype": "Text"
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "Draft\nSubmitted\nApproved\nCleared\nFailed\nCancelled",
