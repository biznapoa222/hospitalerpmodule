  },
  {
   "fieldname": "approved_by",
   "label": "Approved By",
   "fieldtype": "Link",
   "options": "Employee"
  },
  {
   "fieldname": "approved_on",
   "label": "Approved On",
   "fieldtype": "Date"
  },
  {
   "fieldname": "cleared_by",
