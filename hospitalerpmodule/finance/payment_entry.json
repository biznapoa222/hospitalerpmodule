   "options": "Employee"
  },
  {
   "fieldname": "cleared_on",
   "label": "Cleared On",
   "fieldtype": "Date"
  },
  {
   "fieldname": "remarks",
   "label": "Remarks",
   "fieldtype": "Text"
  },
  {
   "fieldname": "department",
   "label": "Department",
   "fieldtype": "Link",
   "options": "Department"
  },
  {
   "fieldname": "project",
   "label": "Project",
   "fieldtype": "Link",
   "options": "Project"
  },
  {
   "fieldname": "cost_center",
   "label": "Cost Center",
   "fieldtype": "Link",
   "options": "Cost Center"
  }
 ],
