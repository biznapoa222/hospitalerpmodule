   "delete": 1
  },
  {
   "role": "Accountant",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0
  },
  {
   "role": "Finance Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0
  }
 ]
