  {
   "role": "Inventory Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0
  },
  {
   "role": "Warehouse Staff",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0
  },
  {
   "role": "Purchase Clerk",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0
  }
 ]
}