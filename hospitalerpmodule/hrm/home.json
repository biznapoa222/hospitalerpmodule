{
  "doctype": "DocType",
  "module": "HRM",
  "name": "Home",
  "description": "Home healthcare management with patient care, visits, and reporting",
  "fields": [
    {
      "fieldname": "home_name",
      "label": "Home Name",
      "fieldtype": "Data",
      "req": 1,
      "unique": 1
    },
    {
      "fieldname": "home_code",
      "label": "Home Code",
      "fieldtype": "Data",
      "req": 1
    },
    {
      "fieldname": "home_type",
      "label": "Home Type",
      "fieldtype": "Select",
      "options": "Private\nShared\nNursing Home\nAssisted Living\nIndependent Living"
    },
    {
      "fieldname": "address",
      "label": "Address",
      "fieldtype": "Text",
      "rows": 3
    },
    {
      "fieldname": "contact_person",
      "label": "Contact Person",
      "fieldtype": "Data"
    },
    {
      "fieldname": "contact_phone",
      "label": "Contact Phone",
      "fieldtype": "Data"
    },
    {
      "fieldname": "is_active",
      "label": "Is Active",
      "fieldtype": "Check",
      "default": 1
    },
    {
      "fieldname": "home_care_start_date",
      "label": "Home Care Start Date",
      "fieldtype": "Date"
    },
    {
      "fieldname": "home_care_end_date",
      "label": "Home Care End Date",
      "fieldtype": "Date"
    },
    {
      "fieldname": "max_capacity",
      "label": "Maximum Capacity",
      "fieldtype": "Int"
    },
    {
      "fieldname": "current_occupancy",
      "label": "Current Occupancy",
      "fieldtype": "Int"
    },
    {
      "fieldname": "show_patient_metrics",
      "label": "Show Patient Metrics",
      "fieldtype": "Check",
      "default": 1
    },
    {
      "fieldname": "show_visit_metrics",
      "label": "Show Visit Metrics",
      "fieldtype": "Check",
      "default": 1
    },
    {
      "fieldname": "show_staff_metrics",
      "label": "Show Staff Metrics",
      "fieldtype": "Check",
      "default": 1
    },
    {
      "fieldname": "show_medication_metrics",
      "label": "Show Medication Metrics",
      "fieldtype": "Check",
      "default": 1
    },
    {
      "fieldname": "show_trend_charts",
      "label": "Show Trend Charts",
      "fieldtype": "Check",
      "default": 1
    },
    {
      "fieldname": "header_text",
      "label": "Header Text",
      "fieldtype": "Small Text"
    },
    {
      "fieldname": "footer_text",
      "label": "Footer Text",
      "fieldtype": "Small Text"
    },
    {
      "fieldname": "description",
      "label": "Description",
      "fieldtype": "Text",
      "rows": 3
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "HR Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    },
    {
      "role": "HR Clerk",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    },
    {
      "role": "Nurse",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    },
    {
      "role": "Doctor",
      "read": 1,
      "write": 0,
      "create": 0,
      "delete": 0
    }
  ]
}